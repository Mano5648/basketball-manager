# Supabase Auth configuration
# Copy this file to `.env.local` and fill in real values from your Supabase project.
# .env.local is gitignored and will NOT be committed.

# Project URL — Supabase dashboard > Project Settings > API > Project URL
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Public anon key — Supabase dashboard > Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Comma-separated list of emails that should be treated as managers.
# Only these emails grant manager access in the app and database RLS.
VITE_MANAGER_EMAILS=manager@dublinlions.ie

# Public site URL used by edge functions for Stripe redirect allowlisting.
# Comma-separate multiple origins if needed (staging + production).
SITE_URL=https://your-domain.com/basketball-manager
ALLOWED_CHECKOUT_ORIGINS=https://your-domain.com/basketball-manager,http://localhost:3000/basketball-manager

# Stripe publishable key — Stripe dashboard > Developers > API keys
# Required for real card payments (redirects to Stripe Checkout).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Edge function secrets (set in Supabase dashboard > Edge Functions > Secrets):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
# PURCHASE_FROM_EMAIL=Dublin Lions BC <orders@yourdomain.com>
# SITE_URL=https://your-domain.com/basketball-manager
# ALLOWED_CHECKOUT_ORIGINS=https://your-domain.com/basketball-manager
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# ALLOW_DEMO_PURCHASE_EMAIL=true   # local dev only — enables mock checkout emails

# Supabase Auth > URL Configuration — add these redirect URLs:
# http://localhost:3000/basketball-manager/#/reset-password
# https://your-domain.com/basketball-manager/#/reset-password

# Cloudflare Turnstile (bot protection) — https://dash.cloudflare.com/
# Privacy-friendly CAPTCHA alternative; optional but recommended for production.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
# Edge function secret:
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key
